generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// O estado do post, garantindo que não existam valores inválidos no banco
enum PostStatus {
  DRAFT
  PUBLISHED
  DELETED
}

// Entidade principal do Apokryphos
model Post {
  id          String     @id @default(uuid())
  title       String
  content     String     // Armazenará a estrutura rica em JSON gerada pelo Tiptap futuramente
  status      PostStatus @default(DRAFT)
  mood        String?    // Opcional, para registrar o estado emocional
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  tags        PostTag[]
}

// Entidade para categorização
model Tag {
  id        String    @id @default(uuid())
  name      String    @unique // Garante que não teremos tags duplicadas
  posts     PostTag[]
  createdAt DateTime  @default(now())
}

// Tabela pivô para o relacionamento N:N entre Post e Tag
model PostTag {
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  // A chave primária composta garante que o mesmo post não tenha a mesma tag duas vezes
  @@id([postId, tagId])
}