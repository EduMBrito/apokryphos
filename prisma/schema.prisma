generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// O estado do post, garantindo que não existam valores inválidos no banco
enum PostStatus {
  DRAFT
  PUBLISHED
  DELETED
}

// Entidade principal do Apokryphos
model Post {
  id          String     @id @default(uuid())
  title       String
  content     String     // Armazenará a estrutura rica em JSON gerada pelo Tiptap futuramente
  status      PostStatus @default(DRAFT)
  mood        String?    // Opcional, para registrar o estado emocional
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  publishedAt DateTime?
  tags        PostTag[]
}

// Entidade para categorização
model Tag {
  id        String    @id @default(uuid())
  name      String    @unique // Garante que não teremos tags duplicadas
  posts     PostTag[]
  createdAt DateTime  @default(now())
}

// Tabela pivô para o relacionamento N:N entre Post e Tag
model PostTag {
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId     String

  // A chave primária composta garante que o mesmo post não tenha a mesma tag duas vezes
  @@id([postId, tagId])
}

// --- MODELOS DO NEXTAUTH ---

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}